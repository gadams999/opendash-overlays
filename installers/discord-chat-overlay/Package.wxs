<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="DiscordChatOverlay"
    Manufacturer="Gavin Adams"
    Version="0.1.0"
    UpgradeCode="DA1C2717-7FF7-4F81-A055-0D33A7CA93C0"
    Compressed="yes">

    <!-- Enforce in-place upgrades; block downgrades with clear message -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of DiscordChatOverlay is already installed. Please uninstall it before installing this version." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Installation directory: Program Files\OpenDash\DiscordChatOverlay -->
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="OpenDashDir" Name="OpenDash">
        <Directory Id="INSTALLFOLDER" Name="DiscordChatOverlay" />
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut directory -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DiscordChatOverlay" />
    </StandardDirectory>

    <!-- Desktop shortcut directory -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- Application data directory: %APPDATA%\DiscordChatOverlay -->
    <StandardDirectory Id="AppDataFolder">
      <Directory Id="AppDataDiscordChatOverlay" Name="DiscordChatOverlay" />
    </StandardDirectory>

    <!-- Application files (populated by generate_components.ps1 / build_msi.ps1) -->
    <Feature Id="MainApplication" Title="DiscordChatOverlay" Level="1">
      <ComponentGroupRef Id="AppComponents" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentRef Id="AppDataDir" />
    </Feature>

    <!-- Start Menu shortcut -->
    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut
        Id="StartMenuShortcut"
        Name="DiscordChatOverlay"
        Description="Discord voice channel activity overlay"
        Target="[INSTALLFOLDER]DiscordChatOverlay.exe"
        WorkingDirectory="INSTALLFOLDER"
        Icon="AppIcon" />
      <RemoveFolder Id="CleanUpStartMenuFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\Gavin Adams\DiscordChatOverlay"
        Name="StartMenuShortcutInstalled"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>

    <!-- Desktop shortcut -->
    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="*">
      <Shortcut
        Id="DesktopShortcut"
        Name="DiscordChatOverlay"
        Description="Discord voice channel activity overlay"
        Target="[INSTALLFOLDER]DiscordChatOverlay.exe"
        WorkingDirectory="INSTALLFOLDER"
        Icon="AppIcon" />
      <RegistryValue
        Root="HKCU"
        Key="Software\Gavin Adams\DiscordChatOverlay"
        Name="DesktopShortcutInstalled"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>

    <!-- Create %APPDATA%\DiscordChatOverlay directory -->
    <Component Id="AppDataDir" Directory="AppDataDiscordChatOverlay" Guid="*">
      <CreateFolder />
      <RegistryValue
        Root="HKCU"
        Key="Software\Gavin Adams\DiscordChatOverlay"
        Name="AppDataDirInstalled"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>

    <!-- App icon for shortcuts -->
    <Icon Id="AppIcon" SourceFile="app.ico" />

  </Package>

  <!-- APPLICATION_FILES_START -->
  <!-- APPLICATION_FILES_END -->

</Wix>
