<Window x:Class="OpenDash.DiscordChatOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OpenDash.DiscordChatOverlay.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection indicator (hidden when null) -->
        <TextBlock Grid.Row="0"
                   Text="{Binding ConnectionIndicator}"
                   Foreground="#FFCC00"
                   FontSize="12"
                   Margin="8,4,8,2"
                   TextOptions.TextFormattingMode="Display">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ConnectionIndicator}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Speaker list -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding ActiveSpeakers}"
                      Margin="4,0,4,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Outer row — opacity drives the fade animation -->
                    <Grid Opacity="{Binding Opacity}" Margin="2,2,2,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar image (Hidden not Collapsed to preserve column width per FR-014b-layout) -->
                        <Image Grid.Column="0"
                               Width="28" Height="28"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Source>
                                <MultiBinding Converter="{StaticResource AvatarUrlConverter}">
                                    <Binding Path="GuildId"/>
                                    <Binding Path="UserId"/>
                                    <Binding Path="GuildAvatarHash"/>
                                    <Binding Path="AvatarHash"/>
                                </MultiBinding>
                            </Image.Source>
                            <Image.Visibility>
                                <Binding Path="AvatarVisible" Converter="{StaticResource BoolToVisibilityConverter}"/>
                            </Image.Visibility>
                        </Image>

                        <!-- Display name -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   Foreground="White"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="6,0,4,0"
                                   TextOptions.TextFormattingMode="Display"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- +N more overflow label -->
        <TextBlock Grid.Row="2"
                   Foreground="#AAAAAA"
                   FontSize="12"
                   Margin="8,2,8,4"
                   TextOptions.TextFormattingMode="Display">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding OverflowCount}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
            <Run Text="+"/>
            <Run Text="{Binding OverflowCount, Mode=OneWay}"/>
            <Run Text=" more"/>
        </TextBlock>
    </Grid>
</Window>
